# -----------------------------------------------------------------------------
# Embeddings Explorer — local dev environment
# -----------------------------------------------------------------------------
# Copy this file to `.env` and fill in your values.
# `.env` is gitignored and is only used for local `npm run dev`.
# In production (deployed as a Databricks App), env vars are injected
# from app.yaml and Databricks App resource bindings.
# -----------------------------------------------------------------------------

# Unity Catalog location for pipeline tables (must match the companion DAB run).
CATALOG=main
SCHEMA=youtube_channels

# Databricks workspace host (no trailing slash). Example:
#   https://dbc-12345678-abcd.cloud.databricks.com
DATABRICKS_HOST=

# SQL Warehouse ID — find in the Databricks UI: SQL > Warehouses > (your warehouse) > Details.
DATABRICKS_WAREHOUSE_ID=

# Personal access token for local dev only.
# Generate: User Settings > Developer > Access tokens.
# DO NOT commit a .env file with a real token.
DATABRICKS_TOKEN=

# Local server port (optional, default 8000).
# PORT=8000
