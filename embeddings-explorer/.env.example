# -----------------------------------------------------------------------------
# Embeddings Explorer — local dev environment
# -----------------------------------------------------------------------------
# Copy this file to `.env` and fill in your values.
# `.env` is gitignored and is only used for local `npm run dev`.
# In production (deployed as a Databricks App), env vars are injected
# from app.yaml and Databricks App resource bindings.
# -----------------------------------------------------------------------------

# Unity Catalog location for pipeline tables (must match the companion DAB run).
CATALOG=main
SCHEMA=youtube_channels

# Pipeline tables. Override these to retarget the app at a different
# taxonomy/dataset without code changes. Defaults below match the companion
# DAB's output table names; only override if your DAB run uses different names.
# TABLE_IAB_VIZ=iab_viz_precomputed
# TABLE_DENDROGRAM=viz_dendrogram_linkage
# TABLE_CHANNELS_OUTPUT=channels_output
# TABLE_CHANNELS_PREPPED=channels_prepped
# TABLE_CHANNELS_EMBEDDINGS=channels_embeddings
# TABLE_CHANNELS_VIZ=channels_viz_sample

# Embedding endpoint. Default databricks-gte-large-en (1024-dim, pay-per-token).
# Override to use a different embedding endpoint without code changes.
# EMBEDDING_ENDPOINT_NAME=databricks-gte-large-en

# Databricks workspace host (no trailing slash). Example:
#   https://dbc-12345678-abcd.cloud.databricks.com
DATABRICKS_HOST=

# SQL Warehouse ID — find in the Databricks UI: SQL > Warehouses > (your warehouse) > Details.
DATABRICKS_WAREHOUSE_ID=

# Personal access token for local dev only.
# Generate: User Settings > Developer > Access tokens.
# DO NOT commit a .env file with a real token.
DATABRICKS_TOKEN=

# Local server port (optional, default 8000).
# PORT=8000
